{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vtests-gui",
  "version": "0.1.0",
  "identifier": "no.davidgrant.vtests-gui",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "vtests-gui",
        "width": 920,
        "height": 1164,
        "minWidth": 920,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: http://asset.localhost; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
